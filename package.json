{
  "name": "kabut-tipis",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@trpc/server": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.91.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @kabut-tipis/db db:push",
    "db:studio": "bun run --filter @kabut-tipis/db db:studio",
    "db:generate": "bun run --filter @kabut-tipis/db db:generate",
    "db:migrate": "bun run --filter @kabut-tipis/db db:migrate",
    "db:local": "bun run --filter @kabut-tipis/db db:local",
    "deploy": "bun run --filter @kabut-tipis/infra deploy",
    "destroy": "bun run --filter @kabut-tipis/infra destroy",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@kabut-tipis/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@kabut-tipis/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.12"
}
